# Configuración del Servidor
PORT=5000
CORS_ORIGIN=http://localhost:5000
ENCRYPT_KEY=cambia-esta-clave-por-una-segura

# Integración Gmail (Nodemailer)
# Opción A: Usar cuenta Gmail directa con App Password
GMAIL_USER=tu-cuenta@gmail.com
GMAIL_APP_PASSWORD=tu-app-password
MAIL_FROM=Dating XML Platform <tu-cuenta@gmail.com>
MAIL_DEFAULT_TO=

# Opción B: Usar servidor SMTP genérico
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Integración Google Drive (Service Account)
# GOOGLE_DRIVE_PARENT_ID: ID de la carpeta raíz donde se crearán los respaldos automáticos
GOOGLE_DRIVE_PARENT_ID=id-de-la-carpeta-padre

# Usar archivo JSON de credenciales o variables individuales
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
